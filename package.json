{
  "name": "pactwire",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Pactwire checks whether school software sends synthetic student information beyond a district's confirmed agreement rules.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": ">=11.6.0 <12"
  },
  "scripts": {
    "workspace:check": "node scripts/check-workspace.mjs",
    "toolchain:check": "node scripts/check-toolchain.mjs",
    "evidence:check": "tsx scripts/check-evidence.ts",
    "domain:evidence:check": "tsx scripts/check-domain-evidence.ts",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit && pnpm -r --if-present typecheck",
    "build": "pnpm -r --if-present build",
    "test:unit": "vitest run --project unit",
    "test:property": "vitest run --project property",
    "test:integration": "vitest run --project integration",
    "test:bdd": "node scripts/run-bdd.mjs",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:security": "vitest run --project security",
    "test:a11y": "vitest run --project a11y",
    "test:live-openai": "vitest run --project live-openai",
    "test:live-computer-use": "vitest run --project live-openai tests/live-openai/computer-use.live.test.ts",
    "verify": "pnpm workspace:check && pnpm toolchain:check && pnpm evidence:check && pnpm domain:evidence:check && pnpm lint && pnpm typecheck && pnpm build && pnpm test:unit && pnpm test:property && pnpm test:integration && pnpm test:bdd -- --production && pnpm test:e2e && pnpm test:security && pnpm test:a11y"
  },
  "devDependencies": {
    "@cucumber/cucumber": "13.1.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "fast-check": "4.9.0",
    "globals": "17.7.0",
    "pdf-lib": "1.17.1",
    "playwright-core": "1.61.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
